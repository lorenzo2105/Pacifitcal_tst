# ────────────────────────────────────────────────────────────────────────────
# PacifitCal — Variables d'Environnement
# ────────────────────────────────────────────────────────────────────────────
# Copiez ce fichier en .env et remplissez avec vos vraies valeurs
# NE COMMITTEZ PAS le fichier .env dans Git (déjà dans .gitignore)
# ────────────────────────────────────────────────────────────────────────────

# ── Firebase Project ID ──────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=votre-project-id

# ── Firebase Region ──────────────────────────────────────────────────────────
# Région pour les Cloud Functions (europe-west1, us-central1, etc.)
FIREBASE_REGION=europe-west1

# ── Firebase Web API Key ─────────────────────────────────────────────────────
FIREBASE_WEB_API_KEY=AIzaSy...

# ── Firebase Android App ID ──────────────────────────────────────────────────
FIREBASE_ANDROID_APP_ID=1:123456789:android:abc123

# ── Firebase iOS App ID ──────────────────────────────────────────────────────
FIREBASE_IOS_APP_ID=1:123456789:ios:def456

# ── Android Package Name ─────────────────────────────────────────────────────
ANDROID_PACKAGE_NAME=com.votresociete.pacifitcal

# ── iOS Bundle ID ────────────────────────────────────────────────────────────
IOS_BUNDLE_ID=com.votresociete.pacifitcal

# ── Notes ────────────────────────────────────────────────────────────────────
# Ces valeurs sont disponibles dans :
# - Firebase Console > Project Settings
# - Après avoir lancé : flutterfire configure
# - Dans les fichiers générés : google-services.json et GoogleService-Info.plist
